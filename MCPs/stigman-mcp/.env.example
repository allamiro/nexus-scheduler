# Copy to .env and fill in. Generate secrets with: openssl rand -hex 24
# Nothing here is optional — compose fails fast on missing values
# (the ${VAR:?set in .env} guards) rather than starting half-configured.

# --- Keycloak ---------------------------------------------------------
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=
KEYCLOAK_DB_PASSWORD=

# --- STIG Manager -----------------------------------------------------
STIGMAN_DB_PASSWORD=
# Password for the stigadmin Keycloak user (STIG Manager application
# admin, created by the realm import).
STIGMAN_ADMIN_PASSWORD=

# --- Host ports (optional overrides) ----------------------------------
# Defaults: Keycloak 8180, STIG Manager 54000, MCP 8005. Uncomment to
# move the lab when a default is already taken on this host; the realm
# import's redirect URIs and the browser-facing issuer follow along.
#KEYCLOAK_HOST_PORT=8180
#STIGMAN_HOST_PORT=54000
#MCP_HOST_PORT=8005

# --- MCP service account (Keycloak confidential client) ---------------
NEXUS_MCP_CLIENT_ID=nexus-mcp
# Substituted into the realm import AND handed to the MCP server; the
# two must match, which is why both read the same variable.
NEXUS_MCP_CLIENT_SECRET=
